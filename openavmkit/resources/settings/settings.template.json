{
	"locality": {},
	"data": {
		"load": {},
		"process": {
			"merge": {},
			"fill": {
				"zero": [
					"bldg_area_finished_sqft",
					"bldg_area_finished_sqm"
				]
			},
			"reconcile": {},
			"enrich": {
				"__census": {
					"__doc": "Optional ACS Census enrichment. Spatially joins American Community Survey block-group data (median_income, median_g_rent, median_c_rent, total_population) onto every parcel. Requires a US Census API key (see README) and a 5-digit state+county FIPS code.",
					"__doc_stamp_regions": "By default (stamp_regions: true) also stamps census_tract (11-digit GEOID) and census_block_group (12-digit GEOID) location columns derived from the block-group GEOID. These auto-classify as categorical locations (already in field_classification + data_dictionary) and can be used by spatial_lag, area_stats, ratio-study breakdowns, and equity studies. Set stamp_regions: false to skip. Existing census_tract/census_block_group columns are never overwritten.",
					"__example": {
						"enabled": true,
						"fips": "51730",
						"year": 2022,
						"stamp_regions": true
					}
				},
				"__area_stats": {
					"__doc": "Optional 'neighborhood enrichment'. Computes per-location summary statistics of the chosen fields and stamps them onto every parcel as area_stat_<location>_<field>_<stat> columns (e.g. area_stat_neighborhood_bldg_area_finished_sqft_mean). A quantized counterpart to spatial_lag; run it in the modeling stage after cleaning, sales scrutiny, and the train/test split. Derived columns are auto-classified (numeric/categorical, land/impr/other) by inheriting their base field's classification, so models discover them automatically.",
					"__doc_leakage": "Sale-derived fields (sale_price and its variants) are aggregated over TRAINING valid sales only; all other fields are aggregated over the full universe. Set exclude_test_keys: true to additionally drop test-key parcels from every aggregation (strict out-of-sample hygiene; off by default).",
					"__doc_locations": "List location fields coarsest -> finest (finest last). Each yields its own independent columns; a group with fewer than min_count observations is left NaN (no fallback) -- rely on the next-coarser location as a separate feature.",
					"__doc_stats": "numeric defaults: mean, median, std. numeric opt-in: cv, p25, p75, iqr, min, max, sum. categorical defaults (categorical_stats): mode, mode_frac. categorical opt-in: nunique, entropy. Per-location counts are always emitted: count (universe parcels), sales_count, sales_count_improved, sales_count_vacant (training valid sales).",
					"__doc_sale_rates": "MAGIC: just list 'sale_price' (or 'sale_price_time_adj' -- treated as aliases) and it auto-expands to the full per-area family using the canonical sale field (time-adjusted price when time_adjustment is on, else raw sale_price -- same convention as elsewhere): the price level plus _impr_<unit> ($/finished-building-area, improved sales), _vacant_land_<unit> ($/land-area, vacant sales -- clean land rate), and _impr_land_<unit> ($/land-area, improved sales -- developed-density rate). All synthesized train-only (leakage-safe). You may still list explicit suffixed fields for fine control; _land_<unit> is an accepted alias of _vacant_land_<unit>.",
					"__example": {
						"locations": ["city", "census_tract", "neighborhood"],
						"fields": ["bldg_area_finished_sqft", "land_area_sqft", "bldg_quality_num", "zoning"],
						"stats": ["mean", "median", "std"],
						"categorical_stats": ["mode", "mode_frac"],
						"min_count": 5,
						"exclude_test_keys": false
					}
				}
			},
			"__collapse_sparse_categories": {
				"__doc": "Optional. Per-field rare-category collapse: any category whose row count is below sales_min in hydrated sales OR below univ_min in the universe is replaced by replacement_value (default 'Other'). Skipped for a field if fewer than 2 categories would collapse. Field must be declared in field_classification.*.categorical.",
				"__doc_output_field": "Optional per-field 'output_field' writes the collapsed result to a NEW column and leaves the source intact -- this is how to collapse a LOCATION field safely (e.g. neighborhood -> neighborhood_collapsed): use the variant ONLY as a model feature and keep the raw location for breakdowns/equity/spatial. Collapsing a location field IN PLACE merges unrelated zones into 'Other' and is warned against loudly. Reserved key 'strict': true escalates those warnings to errors. See advanced_settings.md 5.4.",
				"__example_roof_material": { "sales_min": 2, "univ_min": 5 },
				"__example_roof_shape":    { "sales_min": 2, "univ_min": 5, "replacement_value": "Other Shape" },
				"__example_neighborhood":  { "sales_min": 5, "univ_min": 25, "output_field": "neighborhood_collapsed" }
			}
		}
	},
	"modeling": {
		"metadata": {
			"modeler": "Modeler",
			"__seed": "Random seed for reproducible tree-model tuning/fitting (Optuna sampler, CV folds, final fits). Modeling is always deterministic; XGBoost/LightGBM stay parallel AND reproducible via batched tuning. Change this integer to vary the seed (default 42).",
			"seed": 42
		},
		"instructions": {
			"feature_selection": {
				"thresholds": {
					"correlation": 0.1,
					"vif": 10,
					"p_value": 0.05,
					"t_value": 2,
					"enr_coef": 0.01,
					"adj_r2": 0.05
				},
				"weights": {
					"vif": 3,
					"p_value": 3,
					"t_value": 2,
					"enr_coef": 2,
					"corr_score": 2,
					"coef_sign": 2,
					"adj_r2": 1
				}
			}
		},
		"models": {
			"default": {
				"dep_vars": [],
				"interactions": {
					"default": true
				}
			}
		}
	},
